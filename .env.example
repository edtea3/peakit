TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_TIMEOUT_S=20
SUPABASE_SSL_VERIFY=true
# SUPABASE_CA_BUNDLE=/absolute/path/to/ca.pem
CRON_SECRET=

# Threat detector (aitunnel/openai moderation)
AITUNNEL_API_KEY=
AITUNNEL_BASE_URL=https://api.aitunnel.ru/v1/
THREAT_DETECTOR_MODEL=omni-moderation-latest
THREAT_MIN_SCORE=0.40
SYNC_PARSE_ON_ADD=true
SYNC_REFRESH_BEFORE_THREATS_EXPORT=true
ALERTS_ENABLED=false
AUTO_MONITOR_ENABLED=false
AUTO_MONITOR_INTERVAL_MIN=15
